# Rust build artifacts
/target/
**/*.rs.bk
*.backup
*.pdb
*.rlib
*.rmeta

# Cargo
Cargo.lock

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Debug
debug/
release/
incremental/

